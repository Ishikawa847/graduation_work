<div class="min-h-screen flex items-center justify-center bg-[#1a1a1a] text-gray-100 p-6 selection:bg-white selection:text-black">
  <div class="w-full max-w-[400px]">

    <div class="text-center mb-10">
      <h2 class="text-4xl font-black tracking-tighter mb-2 uppercase italic text-white">
        新しいパスワード設定
      </h2>
    </div>

    <div class="bg-[#242424] border border-white/5 rounded-[2.5rem] p-8 md:p-10 shadow-2xl">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>

        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>

        <div class="space-y-6">

          <div>
            <%= f.label :password, "新しいパスワード",
              class: "block text-[10px] uppercase tracking-[0.2em] font-bold text-gray-500 mb-2 ml-1" %>

            <% if @minimum_password_length %>
              <p class="text-xs text-gray-500 mb-2 ml-1">
                （<%= @minimum_password_length %>文字以上）
              </p>
            <% end %>

            <%= f.password_field :password,
                autofocus: true,
                autocomplete: "new-password",
                placeholder: "••••••••",
                class: "w-full px-5 py-4 bg-[#1a1a1a] border border-white/5 rounded-2xl text-white placeholder-gray-700 focus:outline-none focus:border-white/20 focus:ring-4 focus:ring-white/5 transition-all duration-300" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "新しいパスワード（確認）",
              class: "block text-[10px] uppercase tracking-[0.2em] font-bold text-gray-500 mb-2 ml-1" %>

            <%= f.password_field :password_confirmation,
                autocomplete: "new-password",
                placeholder: "••••••••",
                class: "w-full px-5 py-4 bg-[#1a1a1a] border border-white/5 rounded-2xl text-white placeholder-gray-700 focus:outline-none focus:border-white/20 focus:ring-4 focus:ring-white/5 transition-all duration-300" %>
          </div>

          <div class="pt-2">
            <%= f.submit "パスワードを変更する",
                class: "w-full bg-white text-black font-black uppercase tracking-widest py-4 rounded-2xl shadow-xl hover:bg-gray-200 hover:scale-[1.02] active:scale-[0.98] transition-all duration-300 cursor-pointer" %>
          </div>

        </div>
      <% end %>

      <div class="mt-8 pt-8 border-t border-white/5 text-center">
        <div class="text-[10px] uppercase tracking-widest space-y-3 font-bold text-gray-500">
          <%= render "devise/shared/links" %>
        </div>
      </div>

    </div>

    <div class="mt-8 text-center">
      <%= link_to root_path, class: "text-[10px] uppercase tracking-[0.3em] font-bold text-gray-600 hover:text-white transition-colors" do %>
        ← ホームへ戻る
      <% end %>
    </div>

  </div>
</div>

