<div data-controller="loading">
<div class="container mx-auto px-4 py-12 max-w-2xl">

  <h1 class="text-3xl font-bold text-center mb-8 text-gray-100">
    <%= @recipe.persisted? ? "管理者用 レシピ編集" : "管理者用 レシピ作成" %>
  </h1>

  <%= form_with model: [:admin, @recipe], local: true, multipart: true, class: "space-y-8" do |form| %>

    <% if @recipe.errors.any? %>
      <div class="bg-red-900/40 border border-red-600 text-red-300 px-4 py-3 rounded-lg">
        <h4 class="font-bold">エラーが発生しました:</h4>
        <ul class="mt-2 list-disc pl-5">
          <% @recipe.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :name, class: "block text-gray-200 text-sm font-semibold mb-2" %>
      <%= form.text_field :name,
          class: "bg-gray-800 border border-gray-700 rounded w-full py-3 px-4 text-gray-100" %>
    </div>

    <div>
      <%= form.label :description, class: "block text-gray-200 text-sm font-semibold mb-2" %>
      <%= form.text_area :description, rows: 4,
          class: "bg-gray-800 border border-gray-700 rounded w-full py-3 px-4 text-gray-100" %>
    </div>

    <div data-controller="image-preview">
      <%= form.label :image, class: "block text-gray-200 text-sm font-semibold mb-2" %>

      <div class="border-2 border-dashed border-gray-600 p-6 text-center">
        <img id="image-preview" class="hidden" data-image-preview-target="preview">

        <%= form.file_field :image,
          data: { image_preview_target: "input", action: "change->image-preview#preview" } %>
      </div>
    </div>

    <div>
      <h2 class="text-xl font-bold text-gray-100 mb-4">食材</h2>

      <div id="ingredients-container"
        data-ingredients='<%= @ingredients.to_json(only: [:id, :name, :protein, :fat, :carb]).html_safe %>'>

        <%= form.fields_for :recipe_ingredients do |ingredient_form| %>
          <div class="mb-4">

            <%= ingredient_form.select :ingredient_id,
              options_for_select(
                @ingredients.map { |ing|
                  [ing.name, ing.id]
                },
                ingredient_form.object.ingredient_id
              ),
              { prompt: '-- 選択してください --' } %>

            <%= ingredient_form.number_field :quantity, step: 0.1, placeholder: "100" %>

          </div>
        <% end %>

      </div>

      <button type="button" id="add-ingredient">
        + 食材追加
      </button>
    </div>

    <div class="text-center">
      <%= form.submit @recipe.persisted? ? "更新する" : "作成する",
            class: "bg-blue-600 text-white px-6 py-3 rounded" %>
    </div>

  <% end %>

  <div class="text-center mt-8">
    <%= link_to "一覧に戻る", admin_recipes_path %>
  </div>

</div>

<div data-loading-target="overlay"
     class="hidden fixed inset-0 bg-gray-900 bg-opacity-90 flex items-center justify-center z-50">
  <p class="text-white">処理中...</p>
</div>

</div>