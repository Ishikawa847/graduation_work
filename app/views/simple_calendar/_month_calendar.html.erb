<div class="max-w-4xl mx-auto bg-[#222] rounded-2xl shadow-xl p-4 border border-gray-700">
  
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-xl font-bold text-gray-100">
      <%= start_date.strftime("%Y年 %m月") %>
    </h2>

    <div class="space-x-2">
      <%= link_to "←", calendar.url_for_previous_view,
        class: "px-3 py-1 bg-gray-700 text-gray-200 rounded-lg hover:bg-gray-600 transition" %>

      <%= link_to "今日", calendar.url_for_today_view,
        class: "px-3 py-1 bg-blue-500 text-white rounded-lg hover:bg-blue-600 transition" %>

      <%= link_to "→", calendar.url_for_next_view,
        class: "px-3 py-1 bg-gray-700 text-gray-200 rounded-lg hover:bg-gray-600 transition" %>
    </div>
  </div>

  <table class="w-full table-fixed border-collapse text-sm">
    <thead>
      <tr class="text-gray-400">
        <% date_range.first(7).each do |day| %>
          <th class="py-2 font-medium">
            <%= t('date.abbr_day_names')[day.wday] %>
          </th>
        <% end %>
      </tr>
    </thead>

    <tbody>
      <% date_range.each_slice(7) do |week| %>
        <tr>
          <% week.each do |day| %>
            <td class="
              border border-gray-700 
              h-24 align-top p-2
              bg-[#1f1f1f]
              hover:bg-[#2a2a2a] transition
              <%= 'bg-blue-900/40 border-blue-500' if day == Date.current %>
            ">

              <div class="text-xs font-semibold text-gray-300">
                <%= day.day %>
              </div>

              <div class="mt-1 space-y-1">
                <%= yield day %>
              </div>

            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>