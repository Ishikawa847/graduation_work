<header 
  data-controller="menu"
  class="bg-[#1a1a1a] backdrop-blur-xl border-b border-white/5 sticky top-0 z-50">

  <div class="max-w-7xl mx-auto flex items-center justify-between px-6 md:px-8 py-4">

    <%= link_to root_path, class: "group flex items-center space-x-2" do %>
      <span class="text-2xl font-black tracking-tighter text-white group-hover:text-blue-500 transition-colors duration-300">
        MYMUSCLEMEAL
      </span>
    <% end %>

    <nav class="hidden md:flex items-center space-x-8">
      <%= render "shared/header_links" %>
    </nav>

    <button 
      data-action="click->menu#toggle"
      class="md:hidden text-gray-400 focus:outline-none">
      <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
          d="M4 6h16M4 12h16m-7 6h7"/>
      </svg>
    </button>
  </div>

  <div 
    data-menu-target="panel"
    class="hidden md:hidden px-6 pb-6 space-y-4 bg-[#1a1a1a] border-t border-white/5">
    <%= render "shared/header_links_mobile" %>
  </div>

</header>
