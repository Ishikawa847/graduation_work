<div data-controller="image-preview">
    <%= form.label :image, class: "block text-slate-300 text-sm font-bold mb-2 ml-1" %>
    <div class="relative mt-1 flex justify-center px-6 py-10 border-2 border-slate-700 border-dashed rounded-2xl bg-slate-950/30 hover:bg-slate-900/50 transition-all">
    <div class="text-center space-y-4">
        <img id="image-preview" src="" alt="" class="mx-auto max-h-64 rounded-xl shadow-2xl hidden ring-4 ring-slate-800" data-image-preview-target="preview">

        <button type="button" class="hidden mt-2 px-4 py-2 bg-red-500/20 hover:bg-red-500 text-red-400 hover:text-white border border-red-500/50 rounded-lg text-sm transition-all" 
                data-image-preview-target="removeButton" data-action="click->image-preview#remove">
        <%= t('.delete') %> 
        </button>

        <div data-image-preview-target="uploadIcon" class="bg-slate-800 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg text-blue-400">
        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
        </div>

        <div class="text-slate-300" data-image-preview-target="uploadArea">
        <%= form.file_field :image, class: "sr-only", id: "image-upload", accept: "image/*", 
            data: { image_preview_target: "input", action: "change->image-preview#preview" } %>
        <label for="image-upload" class="cursor-pointer font-bold text-blue-400 hover:text-blue-300 underline-offset-4 hover:underline">
            <%= t('recipes.new.upload_image') %>
        </label>
        <p class="text-sm text-slate-500 mt-1"><%= t('recipes.new.or_drag_and_drop') %></p>
        </div>
    </div>
    </div>
</div>