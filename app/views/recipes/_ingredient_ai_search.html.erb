<div class="relative p-[1px] rounded-3xl bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 shadow-xl" data-controller="ingredient-search">
<div class="bg-slate-900 rounded-[calc(1.5rem-1px)] p-8">
    <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
        <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        AIで食材を検索&登録
    </h3>
    
    <div class="flex flex-col sm:flex-row gap-3">
    <input type="text" data-ingredient-search-target="input" data-action="keydown.enter->ingredient-search#search" placeholder="例: 鶏むね肉"
            class="flex-1 rounded-xl bg-slate-950 border-slate-700 text-slate-100 py-4 px-5 focus:ring-indigo-500 focus:border-indigo-500 shadow-inner">
    <button type="button" data-action="click->ingredient-search#search" data-ingredient-search-target="searchButton"
            class="bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 px-8 rounded-xl transition-all shadow-lg flex items-center justify-center gap-2">
        検索 & 追加
    </button>
    </div>

    <%# 状態表示エリア %>
    <div data-ingredient-search-target="loading" class="hidden mt-4 text-center text-indigo-400 text-sm animate-pulse">AIが検索中...</div>
    <div data-ingredient-search-target="error" class="hidden mt-4 bg-red-900/40 text-red-300 p-3 rounded-xl text-sm border border-red-500/50"></div>
    <div data-ingredient-search-target="success" class="hidden mt-4 bg-green-900/40 text-green-300 p-3 rounded-xl text-sm border border-green-500/50"></div>
</div>
</div>