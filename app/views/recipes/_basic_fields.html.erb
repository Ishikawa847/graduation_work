<div>
    <%= form.label :name, class: "block text-slate-300 text-sm font-bold mb-2 ml-1" %>
    <%= form.text_field :name, 
        class: "bg-slate-950/50 border border-slate-700 rounded-xl w-full py-4 px-5 text-slate-100 placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all shadow-inner" %>
</div>

<div>
    <%= form.label :description, class: "block text-slate-300 text-sm font-bold mb-2 ml-1" %>
    <%= form.text_area :description, rows: 4,
        class: "bg-slate-950/50 border border-slate-700 rounded-xl w-full py-4 px-5 text-slate-100 placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all shadow-inner" %>
</div>