<div data-controller="loading" class="min-h-screen bg-slate-950 text-slate-100">
  <div class="container mx-auto px-4 py-16 max-w-3xl">
    
    <header class="text-center mb-12">
      <h1 class="text-4xl font-extrabold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-emerald-400 mb-2">
        <%= t('recipes.new.title') %>
      </h1>
    </header>

    <%= form_with model: @recipe, local: true, multipart: true, class: "space-y-10" do |form| %>

      <%# エラー表示エリア %>
      <% if @recipe.errors.any? %>
        <div class="bg-red-500/10 border border-red-500/50 backdrop-blur-md text-red-200 px-6 py-4 rounded-2xl shadow-xl shadow-red-900/20">
          <h4 class="font-bold mb-2"><%= t('recipes.new.error_occur') %>:</h4>
          <ul class="list-disc pl-8 text-sm opacity-90">
            <% @recipe.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="bg-slate-900/40 backdrop-blur-xl border border-slate-700/50 p-8 rounded-3xl shadow-2xl ring-1 ring-white/5 space-y-8">
        <div>
          <%= form.label :name, class: "block text-slate-300 text-sm font-bold mb-2 ml-1" %>
          <%= form.text_field :name, 
              class: "bg-slate-950/50 border border-slate-700 rounded-xl w-full py-4 px-5 text-slate-100 placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all shadow-inner" %>
        </div>

        <div>
          <%= form.label :description, class: "block text-slate-300 text-sm font-bold mb-2 ml-1" %>
          <%= form.text_area :description, rows: 4,
              class: "bg-slate-950/50 border border-slate-700 rounded-xl w-full py-4 px-5 text-slate-100 placeholder-slate-600 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all shadow-inner" %>
        </div>

        <%# 画像プレビュー %>
        <div data-controller="image-preview">
          <%= form.label :image, class: "block text-slate-300 text-sm font-bold mb-2 ml-1" %>
          <div class="relative mt-1 flex justify-center px-6 py-10 border-2 border-slate-700 border-dashed rounded-2xl bg-slate-950/30 hover:bg-slate-900/50 transition-all">
            <div class="text-center space-y-4">
              <img id="image-preview" src="" alt="" class="mx-auto max-h-64 rounded-xl shadow-2xl hidden ring-4 ring-slate-800" data-image-preview-target="preview">

              <button type="button" class="hidden mt-2 px-4 py-2 bg-red-500/20 hover:bg-red-500 text-red-400 hover:text-white border border-red-500/50 rounded-lg text-sm transition-all" 
                      data-image-preview-target="removeButton" data-action="click->image-preview#remove">
                <%= t('.delete') %> 
              </button>

              <div data-image-preview-target="uploadIcon" class="bg-slate-800 w-16 h-16 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg text-blue-400">
                <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              </div>

              <div class="text-slate-300" data-image-preview-target="uploadArea">
                <%= form.file_field :image, class: "sr-only", id: "image-upload", accept: "image/*", 
                    data: { image_preview_target: "input", action: "change->image-preview#preview" } %>
                <label for="image-upload" class="cursor-pointer font-bold text-blue-400 hover:text-blue-300 underline-offset-4 hover:underline">
                  <%= t('recipes.new.upload_image') %>
                </label>
                <p class="text-sm text-slate-500 mt-1"><%= t('recipes.new.or_drag_and_drop') %></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <%# 食材セクション %>
      <div class="space-y-6">
        <div class="flex items-center justify-between px-2">
          <h2 class="text-2xl font-bold text-slate-100">食材リスト</h2>
        </div>

        <div id="ingredients-container" 
             data-ingredients='<%= @ingredients.to_json(only: [:id, :name, :protein, :fat, :carb]).html_safe %>'>
          <%= form.fields_for :recipe_ingredients do |ingredient_form| %>
            <div class="ingredient-item bg-slate-900/60 border border-slate-800 p-6 rounded-2xl shadow-lg mb-4">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-xs font-bold text-slate-500 uppercase mb-2 ml-1">食材を選択</label>
                  <%= ingredient_form.select :ingredient_id,
                      options_for_select(@ingredients.map { |ing| [ing.name, ing.id, { 'data-protein': ing.protein, 'data-fat': ing.fat, 'data-carb': ing.carb }] }, ingredient_form.object.ingredient_id),
                      { prompt: '-- 選択してください --' },
                      { class: 'ingredient-select w-full rounded-xl bg-slate-950 border-slate-700 text-slate-100 focus:ring-emerald-500 focus:border-emerald-500' } %>
                  
                  <%# 栄養価表示エリア %>
                  <div class="nutrition-info mt-4 p-4 bg-slate-950/80 rounded-xl border border-slate-800 text-sm" style="display: none;">
                    <div class="grid grid-cols-3 gap-4">
                      <div class="flex flex-col"><span class="text-[10px] text-slate-500 font-bold uppercase">P</span><span class="nutrition-display-protein text-emerald-400 font-mono font-bold">0</span></div>
                      <div class="flex flex-col"><span class="text-[10px] text-slate-500 font-bold uppercase">F</span><span class="nutrition-display-fat text-amber-400 font-mono font-bold">0</span></div>
                      <div class="flex flex-col"><span class="text-[10px] text-slate-500 font-bold uppercase">C</span><span class="nutrition-display-carb text-blue-400 font-mono font-bold">0</span></div>
                    </div>
                  </div>
                </div>

                <div>
                  <label class="block text-xs font-bold text-slate-500 uppercase mb-2 ml-1">使用量</label>
                  <div class="relative">
                    <%= ingredient_form.number_field :quantity, step: 0.1, class: "existing-quantity w-full rounded-xl bg-slate-950 border-slate-700 text-slate-100 focus:ring-emerald-500 focus:border-emerald-500 pr-10", placeholder: "150" %>
                    <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 text-sm font-bold">g</span>
                  </div>
                </div>
              </div>

              <div class="mt-4 flex justify-end">
                <button type="button" class="remove-ingredient text-slate-500 hover:text-red-400 text-xs font-bold flex items-center gap-1 transition-colors">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
                  <%= t('.delete') %>
                </button>
              </div>
            </div>
          <% end %>
        </div>

        <button type="button" id="add-ingredient" class="w-full py-4 border-2 border-dashed border-slate-700 rounded-2xl text-slate-400 font-bold hover:bg-slate-900/50 hover:text-emerald-400 transition-all">
          + 食材を追加
        </button>
      </div>

      <div class="relative p-[1px] rounded-3xl bg-gradient-to-br from-indigo-500 via-purple-500 to-pink-500 shadow-xl" data-controller="ingredient-search">
        <div class="bg-slate-900 rounded-[calc(1.5rem-1px)] p-8">
          <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
             <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
             AIで食材を検索&登録
          </h3>
          
          <div class="flex flex-col sm:flex-row gap-3">
            <input type="text" data-ingredient-search-target="input" data-action="keydown.enter->ingredient-search#search" placeholder="例: 鶏むね肉"
                   class="flex-1 rounded-xl bg-slate-950 border-slate-700 text-slate-100 py-4 px-5 focus:ring-indigo-500 focus:border-indigo-500 shadow-inner">
            <button type="button" data-action="click->ingredient-search#search" data-ingredient-search-target="searchButton"
                    class="bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-4 px-8 rounded-xl transition-all shadow-lg flex items-center justify-center gap-2">
              検索 & 追加
            </button>
          </div>

          <%# 状態表示エリア %>
          <div data-ingredient-search-target="loading" class="hidden mt-4 text-center text-indigo-400 text-sm animate-pulse">AIが検索中...</div>
          <div data-ingredient-search-target="error" class="hidden mt-4 bg-red-900/40 text-red-300 p-3 rounded-xl text-sm border border-red-500/50"></div>
          <div data-ingredient-search-target="success" class="hidden mt-4 bg-green-900/40 text-green-300 p-3 rounded-xl text-sm border border-green-500/50"></div>
        </div>
      </div>

      <%# 送信ボタン %>
      <div class="pt-8">
        <%= form.submit t('recipes.new.new_recipe'), data: { loading_target: "submit" },
            class: "w-full bg-gradient-to-r from-blue-600 to-emerald-600 hover:from-blue-500 hover:to-emerald-500 text-white font-black py-5 px-8 rounded-2xl text-xl transition-all transform hover:scale-[1.02] shadow-2xl cursor-pointer" %>
      </div>
    <% end %>

    <%# ローディングオーバーレイ %>
    <div data-loading-target="overlay" class="hidden fixed inset-0 bg-slate-950/90 backdrop-blur-sm flex items-center justify-center z-50">
      <div class="text-center">
        <div class="animate-spin rounded-full h-16 w-16 border-t-4 border-b-4 border-blue-500 mx-auto"></div>
        <p class="text-white text-xl mt-6 font-bold tracking-widest">POSTING...</p>
      </div>
    </div>
  </div>
</div>