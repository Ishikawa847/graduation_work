<div class="space-y-6">
<div class="flex items-center justify-between px-2">
    <h2 class="text-2xl font-bold text-slate-100">食材リスト</h2>
</div>

<div id="ingredients-container" 
        data-ingredients='<%= @ingredients.to_json(only: [:id, :name, :protein, :fat, :carb]).html_safe %>'>
    <%= form.fields_for :recipe_ingredients do |ingredient_form| %>
      <%= render "ingredient_fields",
      ingredient_form: ingredient_form,
      ingredients: ingredients %>
    <% end %>
</div>

<button type="button" id="add-ingredient" class="w-full py-4 border-2 border-dashed border-slate-700 rounded-2xl text-slate-400 font-bold hover:bg-slate-900/50 hover:text-emerald-400 transition-all">
    + 食材を追加
</button>
</div>